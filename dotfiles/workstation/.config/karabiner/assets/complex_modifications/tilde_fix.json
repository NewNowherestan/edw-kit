{
    "description": "Change §± (section/plus-minus) to `~ (backtick/tilde)",
    "manipulators": [
        {
            "type": "basic",
            "from": {
                "key_code": "non_us_backslash",
                "modifiers": {
                    "optional": [
                        "any"
                    ]
                }
            },
            "to": [
                {
                    "key_code": "grave_accent_and_tilde"
                }
            ]
        }
    ]
}

