[submodule "submodules/homebrew-install"]
	path = submodules/homebrew-install
	url = https://github.com/Homebrew/install

[submodule "opt/vim/bundle/Vundle.vim"]
	path = opt/vim/bundle/Vundle.vim
	url = https://github.com/VundleVim/Vundle.vim
[submodule "dotfiles/shell/.oh-my-zsh"]
	path = tiers/shell/dotfiles/.oh-my-zsh
	url = https://github.com/ohmyzsh/ohmyzsh
[submodule "dotfiles/terminal/.oh-my-zsh/custom/plugins/zsh-autosuggestions"]
	path = tiers/terminal/dotfiles/.config/omz-custom/plugins/zsh-autosuggestions
	url = https://github.com/zsh-users/zsh-autosuggestions
[submodule "dotfiles/terminal/.oh-my-zsh/custom/plugins/auto-notify"]
	path = tiers/terminal/dotfiles/.config/omz-custom/plugins/auto-notify
	url = https://github.com/MichaelAquilina/zsh-auto-notify
[submodule "dotfiles/terminal/.oh-my-zsh/custom/plugins/zsh-you-should-use"]
	path = tiers/terminal/dotfiles/.config/omz-custom/plugins/zsh-you-should-use
	url = https://github.com/MichaelAquilina/zsh-you-should-use
[submodule "dotfiles/terminal/.oh-my-zsh/custom/plugins/fzf-tab"]
	path = tiers/terminal/dotfiles/.config/omz-custom/plugins/fzf-tab
	url = https://github.com/Aloxaf/fzf-tab
[submodule "dotfiles/terminal/.oh-my-zsh/custom/plugins/zsh-syntax-highlighting"]
	path = tiers/terminal/dotfiles/.config/omz-custom/plugins/zsh-syntax-highlighting
	url = https://github.com/zsh-users/zsh-syntax-highlighting
